---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Search from 'astro-pagefind/components/Search.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'A catalog of open-source components across macOS and Xcode releases for Apple silicon.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="macOSdb" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    {ogImageURL && <meta property="og:image:width" content="1200" />}
    {ogImageURL && <meta property="og:image:height" content="630" />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImageURL ? 'summary_large_image' : 'summary'} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <!-- Security -->
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="64x64" href="/apple-touch-icon.png" />

    <title>{title}</title>
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header>
      <nav aria-label="Main navigation">
        <a href="/" class="site-title" transition:name="site-title">macOSdb</a>
        <div class="nav-links">
          <a href="/macos/">macOS</a>
          <a href="/xcode/">Xcode</a>
          <a href="/components/">Components</a>
          <a href="/compare/">Compare</a>
          <a href="/api/">API</a>
          <a href="/about/">About</a>
          <div class="search-wrapper">
            <Search
              instance="header"
              className="header-search"
              searchboxOptions={{ placeholder: 'Search', 'hide-shortcut': true, 'show-keyboard-hints': false }}
            />
            <script is:inline>
              function labelSearchInput() {
                const sb = document.querySelector('.header-search');
                if (!sb) return;
                const input = sb.querySelector('.pf-searchbox-input');
                if (input) {
                  input.setAttribute('aria-label', 'Search this site');
                  return;
                }
                new MutationObserver((_, obs) => {
                  const el = sb.querySelector('.pf-searchbox-input');
                  if (el) {
                    el.setAttribute('aria-label', 'Search this site');
                    obs.disconnect();
                  }
                }).observe(sb, { childList: true, subtree: true });
              }
              labelSearchInput();
              document.addEventListener('astro:page-load', labelSearchInput);
            </script>
          </div>
          <a href="https://github.com/starhaven-io/macOSdb" class="github-link" aria-label="GitHub repository">
            <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
          </a>
        </div>
        <div class="mobile-actions">
          <a href="https://github.com/starhaven-io/macOSdb" class="github-link-mobile" aria-label="GitHub repository">
            <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
          </a>
          <button class="menu-toggle" aria-label="Open navigation menu" aria-expanded="false">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path
                d="M2 4.5h16M2 10h16M2 15.5h16"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                fill="none"></path>
            </svg>
          </button>
        </div>
      </nav>
    </header>
    <div class="mobile-nav-overlay" aria-hidden="true">
      <div class="mobile-nav">
        <button class="mobile-nav-close" aria-label="Close navigation menu">&times;</button>
        <a href="/macos/">macOS</a>
        <a href="/xcode/">Xcode</a>
        <a href="/components/">Components</a>
        <a href="/compare/">Compare</a>
        <a href="/api/">API</a>
        <a href="/about/">About</a>
        <a href="https://github.com/starhaven-io/macOSdb">GitHub</a>
      </div>
    </div>
    <main id="main-content" data-pagefind-body>
      <slot />
    </main>
    <footer>
      <p>
        Data licensed under <a href="https://creativecommons.org/licenses/by/4.0/">CC-BY-4.0</a>. Code licensed under <a
          href="https://www.gnu.org/licenses/agpl-3.0.html">AGPL-3.0-only</a
        >.
      </p>
    </footer>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 200;
    padding: 0.5rem 1rem;
    background: var(--color-link);
    color: #fff;
    border-radius: 0 0 6px 6px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 0;
  }

  header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 2rem;
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .mobile-actions {
    display: none;
    align-items: center;
    gap: 0.75rem;
  }

  .github-link-mobile {
    display: flex;
    color: var(--color-text-secondary);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: 0.25rem;
  }

  .mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 150;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    animation: fadeIn 0.15s ease-out;
  }

  .mobile-nav-overlay.open {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
  }

  .mobile-nav {
    background: var(--color-bg);
    border-left: 1px solid var(--color-border);
    width: 260px;
    height: 100%;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    animation: slideIn 0.15s ease-out;
  }

  .mobile-nav a {
    color: var(--color-text);
    font-size: 1.1rem;
    font-weight: 500;
    text-decoration: none;
  }

  .mobile-nav a:hover {
    color: var(--color-link);
  }

  .mobile-nav-close {
    align-self: flex-end;
    background: none;
    border: none;
    color: var(--color-text-secondary);
    font-size: 1.75rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes slideIn {
    from {
      transform: translateX(100%);
    }
    to {
      transform: translateX(0);
    }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-links a {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .search-wrapper {
    position: relative;
  }

  .search-wrapper :global(pagefind-searchbox) {
    --pf-text: var(--color-text);
    --pf-text-secondary: var(--color-text-secondary);
    --pf-text-muted: var(--color-text-secondary);
    --pf-background: var(--color-bg);
    --pf-border: var(--color-border);
    --pf-border-focus: var(--color-text-secondary);
    --pf-hover: var(--color-bg-secondary);
    --pf-outline-focus: var(--color-link);
    --pf-font: var(--font-system);
    --pf-border-radius: 6px;
    --pf-input-height: 32px;
    --pf-input-font-size: 0.9rem;
    --pf-searchbox-max-width: 220px;
    --pf-searchbox-dropdown-max-height: min(70vh, 500px);
    font-size: 0.9rem;
  }

  .search-wrapper :global(.pf-searchbox-dropdown) {
    left: auto;
    right: 0;
    width: 500px;
    min-width: 100%;
  }

  .github-link {
    display: flex;
  }

  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .site-title:hover {
    text-decoration: none;
    opacity: 0.8;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    max-width: var(--max-width);
    margin: 4rem auto 0;
  }

  footer p {
    margin-bottom: 0.25rem;
  }

  footer a {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    header {
      padding: 0.75rem 1rem;
    }

    nav {
      gap: 0.75rem;
    }

    .mobile-actions {
      display: flex;
    }

    .menu-toggle {
      display: block;
    }

    .nav-links {
      display: none;
    }

    .search-wrapper :global(pagefind-searchbox) {
      --pf-searchbox-max-width: 180px;
      --pf-input-height: 30px;
    }

    .search-wrapper :global(.pf-searchbox-dropdown) {
      width: calc(100vw - 1rem);
      max-width: calc(100vw - 1rem);
      right: -0.5rem;
    }

    main {
      padding: 1.25rem 1rem;
    }

    footer {
      padding: 1.5rem 1rem;
      margin-top: 2rem;
    }
  }
</style>

<script>
  function initMobileNav() {
    const toggle = document.querySelector('.menu-toggle');
    const overlay = document.querySelector('.mobile-nav-overlay');
    const close = document.querySelector('.mobile-nav-close');
    if (!toggle || !overlay || !close) return;

    function open() {
      overlay.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
    }

    function shut() {
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', open);
    close.addEventListener('click', shut);
    overlay.addEventListener('click', (e: Event) => {
      if (e.target === overlay) shut();
    });
  }

  document.addEventListener('astro:page-load', initMobileNav);
</script>
